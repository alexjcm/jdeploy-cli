{
  "name": "jbdeploy",
  "type": "module",
  "main": "./dist/index.js",
  "version": "1.3.0",
  "description": "CLI tool to deploy EAR/WAR artifacts to JBoss or Wildfly with automatic build detection.",
  "author": "Alex JCM",
  "license": "MIT",
  "keywords": ["jboss", "wildfly", "deploy", "cli", "tool", "java", "maven", "gradle"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexjcm/jbdeploy.git"
  },
  "bugs": {
    "url": "https://github.com/alexjcm/jbdeploy/issues"
  },
  "homepage": "https://github.com/alexjcm/jbdeploy#readme",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "jbdeploy": "dist/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --watch --import tsx src/cli.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "npm@11.4.2+sha512.f90c1ec8b207b625d6edb6693aef23dacb39c38e4217fe8c46a973f119cab392ac0de23fe3f07e583188dae9fd9108b3845ad6f525b598742bd060ebad60bff3"
}
